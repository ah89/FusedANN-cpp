+class Sift1MFilterDataset(DatasetCompetitionFormat):
+    """Filtered k-NN variant backed by the classic SIFT1M descriptors."""
+
+    def __init__(self):
+        self.nb = 10 ** 6
+        self.d = 128
+        self.nq = 10000
+        self.dtype = "float32"
+        self.ds_fn = "sift1m.base.fbin"
+        self.qs_fn = "sift1m.query.public.10K.fbin"
+        self.gt_fn = "sift1m.GT.public.ibin"
+        self.ds_metadata_fn = "sift1m.base.metadata.spmat"
+        self.qs_metadata_fn = "sift1m.query.metadata.public.spmat"
+        self.base_url = None
+        self.basedir = os.path.join(BASEDIR, "sift1m-filter")
+
+    def prepare(self, skip_data=False):
+        del skip_data  # interface parity; nothing to download
+        os.makedirs(self.basedir, exist_ok=True)
+        required = (
+            self.ds_fn,
+            self.qs_fn,
+            self.gt_fn,
+            self.ds_metadata_fn,
+            self.qs_metadata_fn,
+        )
+        missing = [name for name in required if not os.path.exists(os.path.join(self.basedir, name))]
+        if missing:
+            raise RuntimeError(
+                "Sift1M filter dataset missing files: " + ", ".join(missing)
+            )
+
+    def get_dataset_metadata(self):
+        return read_sparse_matrix(os.path.join(self.basedir, self.ds_metadata_fn))
+
+    def get_queries_metadata(self):
+        return read_sparse_matrix(os.path.join(self.basedir, self.qs_metadata_fn))
+
+    def distance(self):
+        return "euclidean"
+
+    def search_type(self):
+        return "knn_filtered"
+
+
 def _strip_gz(filename):
     if not filename.endswith('.gz'):
         raise RuntimeError(f"expected a filename ending with '.gz'. Received: {filename}")
